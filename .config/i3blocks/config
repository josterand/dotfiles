full_text=|
align=center
separator=false
separator_block_width=12
markup=none

[bandwidth]
command=~/.config/i3blocks/scripts/bandwidth
interval=1
separator=false
#INTERFACE=eth0
#TREAT_UNKNOWN_AS_UP=0

[separator]

[cpu_usage]
# The script may be called with -w and -c switches to specify thresholds,
# see the script for details.
command=~/.config/i3blocks/scripts/cpu_usage
label= 
interval=1
separator=false
#DECIMALS=0

[separator]

[memory]
command=echo -n "  "; ~/.config/i3blocks/scripts/memory
separator=false
interval=1
separator=false

[separator]

[volume]
command=echo -n "  "; ~/.config/i3blocks/scripts/volume
interval=1
signal=5
separator=false

[separator]

[battery]
command=echo -n '  '; ~/.config/i3blocks/scripts/battery
interval=1
separator=false

[separator]

[user]
label= 
command=lslogins | grep $USER | awk '{print $2}'
interval=once
separator=false

[separator]

[date]
label= 
command=date '+%Y-%m-%d'
interval=1
separator=false

[separator]

[time]
label=󰥔 
command=date '+%H:%M'
interval=1
separator=false

[separator]
